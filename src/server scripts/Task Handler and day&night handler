local function givetasks(player)
	playerstasks[player.UserId] = {}
	playersmaintasks[player.UserId] = {}

	while #playerstasks[player.UserId] < 6 do
		local random = math.random(1, #tasks)
		if not table.find(playerstasks[player.UserId], tasks[random]) then
			table.insert(playerstasks[player.UserId], tasks[random])
			local addvalue = Instance.new("BoolValue") --create value to monitor tasks if it been completed
			addvalue.Name = tasks[random].Tasks
			addvalue.Parent = player
			
			re:FireClient(player,"Task", tasks[random].Tasks,tasks[random].obj,tasks[random].Todo)
			-- Monitor this task
			monitorTask(player, addvalue)
		end
		task.wait(0.025)

	end

	while #playersmaintasks[player.UserId] < 3 do
		local random = math.random(1, #maintasks)
		if not table.find(playersmaintasks[player.UserId], maintasks[random]) then
			table.insert(playersmaintasks[player.UserId], maintasks[random])
			local addvalue = Instance.new("BoolValue") --create value to monitor tasks if it been completed
			addvalue.Name = maintasks[random].Tasks
			addvalue.Parent = player
			re:FireClient(player,"Task", maintasks[random].Tasks, maintasks[random].obj,maintasks[random].Todo)
			-- Monitor this task
			monitorTask(player, addvalue)
		end
		task.wait(0.025)

	end


	print("Player:", player.Name, "Tasks: ", playerstasks[player.UserId])
end
--Intermission
local function intermission()
	print("Intermission time")

	for _, player in ipairs(players:GetPlayers()) do
		local totalReward = 0
		local tasknumber = 0
		local taskcompleted = 0
		
		for _, v in ipairs(tasks) do
			local taskValue = player:FindFirstChild(v.Tasks) -- get the BoolValue on the player
			if taskValue then
				tasknumber+=1
				if taskValue.Value == true then
					print(player.Name .. " completed: " .. v.Tasks)
					totalReward += v.Reward
					taskcompleted += 1
				else
					print(player.Name .. " failed: " .. v.Tasks)
					
				end
				taskValue:Destroy() -- clean up after checking
			end
			
		end
		
		for _, v in ipairs(maintasks) do
			local taskValue = player:FindFirstChild(v.Tasks) -- get the BoolValue on the player

			if taskValue then
				tasknumber +=1
				if taskValue.Value == true then
					print(player.Name .. " completed: " .. v.Tasks)
					totalReward += v.Reward
					taskcompleted+=1
				else
					print(player.Name .. " failed: " .. v.Tasks)
					--totalReward -= v.Reward
				end
				taskValue:Destroy() -- clean up after checking
			end
		end
		local done = false
		print("Player has done",taskcompleted, "amount of task")
		if taskcompleted >= tasknumber/2 then
			
			print("You've done enough")
			-- reward system
			done  = true
		else
			print("You failed to meet qouta")
			done = false 
			
			--punishment here
		end
		if player.ValueCheck.JustJoined.Value == true then
			player.ValueCheck.JustJoined.Value = false
			totalReward /= 2
			totalReward *= player.ValueCheck.Multiplier.Value


		end
		
		local gui = script.Parent.Tasks.reward
		local mainframes = gui.Frame.MainFrame 
		local questdone  = mainframes.questdone

		local halfquests  = mainframes.halfquests

		local quotareach  = mainframes.Quotareach

