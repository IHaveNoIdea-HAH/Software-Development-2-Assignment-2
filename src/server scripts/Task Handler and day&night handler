-- Day and night function

local function transitionToTime(targetSettings, duration)
	local startBrightness = lighting.Brightness
	local startAmbient = lighting.Ambient
	local startClock = lighting.ClockTime

	local elapsed = 0

	while elapsed < duration do
		elapsed = elapsed + 0.1
		local progress = elapsed / duration

		-- Smoothly transition brightness
		lighting.Brightness = startBrightness + (targetSettings.Brightness - startBrightness) * progress

		-- Smoothly transition ambient color
		lighting.Ambient = Color3.new(
			startAmbient.R + (targetSettings.Ambient.R - startAmbient.R) * progress,
			startAmbient.G + (targetSettings.Ambient.G - startAmbient.G) * progress,
			startAmbient.B + (targetSettings.Ambient.B - startAmbient.B) * progress
		)

		-- Update clock time
		lighting.ClockTime = startClock + (targetSettings.ClockTime - startClock) * progress

		task.wait(0.1)
	end

	-- Set to exact values
	lighting.Brightness = targetSettings.Brightness
	lighting.Ambient = targetSettings.Ambient
	lighting.ClockTime = targetSettings.ClockTime
end

