local function leaving(player) --saves data when they leave
	print("Saving data")
	if session[player.UserId] then --just realised
		local success  --reason why we have these success and error as local

		local error  --is because we need to repeat the setting the user data in the case it fails
		local attempt = 1 --thus we have these attempts. Pretty cool ngl.
		repeat
			success, error = pcall(function()
				database:SetAsync(player.UserId, session[player.UserId]) --creates data and sync the data. wait its to grab some data from the player inside the session
			end)
			attempt += 1 
			if not success then
				warn(error)
				print("Failed to save") 
				task.wait(1)

			end



		until success or attempt == 5

		if success then
			print("Data save... Nice ig")--i swear there was something here i was suppose to add. unless i'm crazy
		end

	end
	
	
end
players.PlayerRemoving:Connect(leaving) --checks if player leaves

